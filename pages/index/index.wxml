<view style="padding: 20rpx; background: #f5f5f5; min-height: 100vh;">
  <!-- 错误提示 -->
  <view wx:if="{{error}}" style="background: #ffebee; color: #c62828; padding: 20rpx; border-radius: 16rpx; margin-bottom: 20rpx;">
    <text>{{error}}</text>
  </view>

  <!-- 状态卡片 -->
  <view style="background: linear-gradient(135deg, #2196F3, #1976D2); color: #fff; border-radius: 16rpx; padding: 30rpx;">
    <text style="font-size: 36rpx; font-weight: bold;">{{isConnected ? (connectedDevice.name || connectedDevice.localName || '已连接') : '未连接设备'}}</text>
    <text style="font-size: 26rpx; opacity: 0.9; margin-top: 10rpx; display: block;">{{isConnected ? '已连接' : '未连接'}}</text>
    
    <view style="margin-top: 30rpx;">
      <button wx:if="{{!isConnected && !scanning}}" 
              style="background: #fff; color: #2196F3; border: none; border-radius: 12rpx; padding: 24rpx 40rpx;" 
              bindtap="scanDevices">
        扫描设备
      </button>
      <button wx:if="{{scanning}}" 
              style="background: #fff; color: #999; border: none; border-radius: 12rpx; padding: 24rpx 40rpx;" 
              disabled="{{true}}">
        扫描中(10秒)...
      </button>
      <button wx:if="{{isConnected}}" 
              style="background: rgba(255,255,255,0.2); color: #fff; border: none; border-radius: 12rpx; padding: 24rpx 40rpx;" 
              bindtap="disconnect">
        断开连接
      </button>
    </view>
  </view>

  <!-- 设备列表 -->
  <view wx:if="{{devices.length > 0 && !isConnected}}" style="margin-top: 30rpx;">
    <text style="font-size: 28rpx; color: #666; display: block; margin-bottom: 20rpx;">发现的设备 ({{devices.length}})</text>
    
    <view style="background: #fff; border-radius: 16rpx; overflow: hidden;">
      <view wx:for="{{devices}}" wx:key="deviceId" 
            style="padding: 24rpx; border-bottom: 1rpx solid #f0f0f0; display: flex; align-items: center;"
            data-id="{{item.deviceId}}" 
            bindtap="connectDevice">
        <view style="flex: 1;">
          <text style="font-size: 32rpx; font-weight: 500; color: #333; display: block;">{{item.name || item.localName || '未知设备'}}</text>
          <text style="font-size: 24rpx; color: #999; margin-top: 8rpx; display: block;">信号: {{item.RSSI}} dBm</text>
        </view>
        <text style="font-size: 26rpx; color: #2196F3; padding: 12rpx 24rpx; background: #e3f2fd; border-radius: 8rpx;">连接</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:if="{{devices.length === 0 && !scanning && !isConnected}}" 
        style="text-align: center; padding: 100rpx 40rpx; color: #999;">
    <text style="font-size: 28rpx; display: block;">点击"扫描设备"开始搜索</text>
    <text style="font-size: 24rpx; margin-top: 20rpx; display: block;">确保手机蓝牙已开启</text>
    <text style="font-size: 24rpx; margin-top: 10rpx; display: block;">确保 Meshtastic 设备已开机</text>
  </view>

  <!-- 扫描中 -->
  <view wx:if="{{scanning}}" style="text-align: center; padding: 60rpx 40rpx; color: #2196F3;">
    <text style="font-size: 28rpx;">🔍 正在搜索蓝牙设备...</text>
    <text style="font-size: 24rpx; margin-top: 20rpx; display: block;">请确保设备已开机</text>
  </view>

  <!-- 使用说明 -->
  <view wx:if="{{!isConnected}}" style="background: #fff; border-radius: 16rpx; padding: 24rpx; margin-top: 30rpx;">
    <text style="font-size: 30rpx; font-weight: 600; color: #333; display: block; margin-bottom: 16rpx;">使用说明</text>
    <text style="font-size: 26rpx; color: #666; display: block; line-height: 2;">1. 开启手机蓝牙</text>
    <text style="font-size: 26rpx; color: #666; display: block; line-height: 2;">2. 确保 Meshtastic 设备已开机</text>
    <text style="font-size: 26rpx; color: #666; display: block; line-height: 2;">3. 点击扫描设备进行连接</text>
  </view>
</view>