<view style="height: 100vh; display: flex; flex-direction: column; background: #f5f5f5;">
  <!-- 未连接 -->
  <view wx:if="{{!isConnected}}" style="flex: 1; display: flex; align-items: center; justify-content: center; flex-direction: column;">
    <text style="font-size: 80rpx; margin-bottom: 30rpx;">💬</text>
    <text style="color: #999; font-size: 28rpx;">请先连接设备</text>
    <navigator url="/pages/devices/devices" open-type="switchTab" style="margin-top: 30rpx;">
      <button style="background: #2196F3; color: #fff; padding: 20rpx 50rpx; border-radius: 12rpx;">去连接</button>
    </navigator>
  </view>

  <!-- 消息列表 -->
  <scroll-view wx:if="{{isConnected}}" style="flex: 1; padding: 20rpx;" scroll-y>
    <view wx:for="{{messages}}" wx:key="id" style="margin-bottom: 20rpx; display: flex; {{item.type === 'sent' ? 'justify-content: flex-end;' : 'justify-content: flex-start;'}}">
      <view style="max-width: 70%; padding: 20rpx; border-radius: 16rpx; background: {{item.type === 'sent' ? '#2196F3' : '#fff'}};">
        <text style="font-size: 28rpx; color: {{item.type === 'sent' ? '#fff' : '#333'}};">{{item.text}}</text>
        <text style="font-size: 22rpx; color: {{item.type === 'sent' ? 'rgba(255,255,255,0.7)' : '#999'}}; margin-top: 10rpx; display: block;">{{item.time}}</text>
      </view>
    </view>
  </scroll-view>

  <!-- 输入框 -->
  <view wx:if="{{isConnected}}" style="padding: 20rpx; background: #fff; display: flex; border-top: 1rpx solid #eee;">
    <input style="flex: 1; background: #f5f5f5; border-radius: 16rpx; padding: 16rpx 24rpx;" 
           value="{{inputText}}" 
           bindinput="onInput" 
           placeholder="输入消息..." />
    <button style="width: 140rpx; margin-left: 16rpx; background: #2196F3; color: #fff; border-radius: 12rpx;" 
            bindtap="sendMessage">发送</button>
  </view>
</view>