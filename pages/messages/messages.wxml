<view class="page" style="height: 100vh; display: flex; flex-direction: column;">
  <view wx:if="{{!connected}}" style="flex: 1; display: flex; align-items: center; justify-content: center;">
    <view style="text-align: center;">
      <text style="color: #999;">请先连接设备</text>
      <navigator url="/pages/index/index" open-type="switchTab"><button class="btn-primary" style="margin-top: 20rpx;">去连接</button></navigator>
    </view>
  </view>
  <scroll-view wx:if="{{connected}}" style="flex: 1; padding: 20rpx;" scroll-y>
    <view wx:for="{{messages}}" wx:key="id" style="margin-bottom: 20rpx; display: flex; {{item.type === 'sent' ? 'justify-content: flex-end;' : ''}}">
      <view style="max-width: 70%; padding: 20rpx; border-radius: 16rpx; background: {{item.type === 'sent' ? '#e3f2fd' : '#fff'}};">
        <text style="font-size: 28rpx;">{{item.text}}</text>
        <text style="font-size: 22rpx; color: #999; margin-top: 10rpx;">{{item.time}}</text>
      </view>
    </view>
  </scroll-view>
  <view wx:if="{{connected}}" style="padding: 20rpx; background: #fff; display: flex;">
    <input style="flex: 1; background: #f5f5f5; border-radius: 16rpx; padding: 16rpx;" value="{{inputText}}" bindinput="onInput" placeholder="输入消息..." />
    <button style="width: 140rpx; margin-left: 16rpx;" class="btn-primary" bindtap="sendMessage">发送</button>
  </view>
</view>