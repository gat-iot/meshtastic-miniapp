<view style="height: 100vh; display: flex; flex-direction: column; background: #f5f5f5;">
  <!-- 未连接 -->
  <view wx:if="{{!connected}}" style="flex: 1; display: flex; align-items: center; justify-content: center;">
    <view style="text-align: center;">
      <text style="font-size: 80rpx; display: block; margin-bottom: 20rpx;">💬</text>
      <text style="color: #999; font-size: 28rpx; display: block;">请先在设备页面连接</text>
      <navigator url="/pages/devices/devices" open-type="switchTab" style="margin-top: 30rpx;">
        <button style="background: #2196F3; color: #fff; padding: 20rpx 50rpx; border-radius: 12rpx;">去连接</button>
      </navigator>
    </view>
  </view>

  <!-- 已连接 - 消息列表 -->
  <scroll-view wx:if="{{connected}}" style="flex: 1; padding: 20rpx;" scroll-y scroll-into-view="msg-bottom">
    <view wx:for="{{messages}}" wx:key="id" id="msg-{{item.id}}"
          style="margin-bottom: 20rpx; display: flex; {{item.type === 'sent' ? 'justify-content: flex-end;' : 'justify-content: flex-start;'}}">
      <view style="max-width: 70%; padding: 20rpx 24rpx; border-radius: 16rpx; background: {{item.type === 'sent' ? '#2196F3' : '#fff'}};">
        <text style="font-size: 28rpx; color: {{item.type === 'sent' ? '#fff' : '#333'}}; word-break: break-all;">{{item.text}}</text>
        <text style="font-size: 20rpx; color: {{item.type === 'sent' ? 'rgba(255,255,255,0.7)' : '#999'}}; margin-top: 8rpx; display: block;">{{item.time}}</text>
      </view>
    </view>
    <view id="msg-bottom"></view>
  </scroll-view>

  <!-- 输入框 -->
  <view wx:if="{{connected}}" style="padding: 20rpx; background: #fff; display: flex; align-items: center; border-top: 1rpx solid #eee;">
    <input style="flex: 1; background: #f5f5f5; border-radius: 16rpx; padding: 18rpx 24rpx; font-size: 28rpx;"
           value="{{inputText}}"
           bindinput="onInput"
           placeholder="输入消息..."
           confirm-type="send"
           bindconfirm="sendMessage" />
    <button style="width: 140rpx; margin-left: 16rpx; background: #2196F3; color: #fff; border-radius: 12rpx; padding: 18rpx 0; font-size: 28rpx;"
            bindtap="sendMessage">发送</button>
  </view>
</view>