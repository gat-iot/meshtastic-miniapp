<view style="padding: 20rpx; background: #f5f5f5; min-height: 100vh;">
  <!-- 设备状态 -->
  <view style="background: #fff; border-radius: 16rpx; padding: 30rpx; margin-bottom: 20rpx;">
    <text style="font-size: 30rpx; font-weight: bold; color: #333; display: block; margin-bottom: 20rpx;">设备状态</text>
    <view wx:if="{{connected}}">
      <text style="font-size: 32rpx; color: #333; display: block;">{{deviceName}}</text>
      <view style="display: flex; align-items: center; margin-top: 8rpx;">
        <view style="width: 12rpx; height: 12rpx; background: #4caf50; border-radius: 50%; margin-right: 10rpx;"></view>
        <text style="font-size: 24rpx; color: #4caf50;">已连接</text>
      </view>
      <button bindtap="disconnect" style="margin-top: 24rpx; background: #fff; color: #f44336; border: 2rpx solid #f44336; border-radius: 12rpx; padding: 20rpx; font-size: 28rpx;">
        断开连接
      </button>
    </view>
    <view wx:if="{{!connected}}">
      <view style="display: flex; align-items: center;">
        <view style="width: 12rpx; height: 12rpx; background: #ccc; border-radius: 50%; margin-right: 10rpx;"></view>
        <text style="font-size: 28rpx; color: #999;">未连接</text>
      </view>
      <navigator url="/pages/devices/devices" open-type="switchTab">
        <button style="margin-top: 20rpx; background: #2196F3; color: #fff; border-radius: 12rpx; padding: 20rpx; font-size: 28rpx;">
          去连接设备
        </button>
      </navigator>
    </view>
  </view>

  <!-- 设置列表 -->
  <view style="background: #fff; border-radius: 16rpx; overflow: hidden;">
    <view style="padding: 28rpx 24rpx; border-bottom: 1rpx solid #f0f0f0; display: flex; align-items: center; justify-content: space-between;" bindtap="clearMessages">
      <text style="font-size: 30rpx; color: #333;">清除消息记录</text>
      <text style="font-size: 36rpx; color: #ccc;">›</text>
    </view>
    <view style="padding: 28rpx 24rpx; display: flex; align-items: center; justify-content: space-between;" bindtap="showAbout">
      <text style="font-size: 30rpx; color: #333;">关于</text>
      <text style="font-size: 36rpx; color: #ccc;">›</text>
    </view>
  </view>

  <!-- 版本 -->
  <view style="text-align: center; margin-top: 60rpx;">
    <text style="font-size: 24rpx; color: #ccc;">Meshtastic MiniApp {{version}}</text>
  </view>
</view>