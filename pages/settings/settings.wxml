<view style="padding: 20rpx; background: #f5f5f5; min-height: 100vh;">
  <!-- 设备信息 -->
  <view style="background: #fff; border-radius: 16rpx; padding: 30rpx; margin-bottom: 20rpx;">
    <text style="font-size: 30rpx; font-weight: bold; color: #333; display: block; margin-bottom: 20rpx;">当前设备</text>
    
    <view wx:if="{{isConnected}}">
      <text style="font-size: 32rpx; color: #333; display: block;">{{deviceName}}</text>
      <text style="font-size: 24rpx; color: #4caf50; margin-top: 8rpx; display: block;">已连接</text>
      <button bindtap="disconnect" style="margin-top: 24rpx; background: #fff; color: #f44336; border: 2rpx solid #f44336; border-radius: 12rpx; padding: 20rpx;">
        断开连接
      </button>
    </view>
    
    <view wx:if="{{!isConnected}}">
      <text style="font-size: 30rpx; color: #999;">未连接设备</text>
      <navigator url="/pages/index/index" open-type="switchTab">
        <button style="margin-top: 20rpx; background: #2196F3; color: #fff; border-radius: 12rpx; padding: 20rpx;">
          去连接设备
        </button>
      </navigator>
    </view>
  </view>

  <!-- 设置选项 -->
  <view style="background: #fff; border-radius: 16rpx; overflow: hidden;">
    <view style="padding: 28rpx 24rpx; border-bottom: 1rpx solid #f0f0f0; display: flex; align-items: center; justify-content: space-between;" bindtap="showAbout">
      <text style="font-size: 30rpx; color: #333;">关于</text>
      <text style="font-size: 36rpx; color: #ccc;">›</text>
    </view>
  </view>

  <!-- 版本 -->
  <view style="text-align: center; margin-top: 40rpx;">
    <text style="font-size: 24rpx; color: #999;">Meshtastic MiniApp {{version}}</text>
  </view>
</view>